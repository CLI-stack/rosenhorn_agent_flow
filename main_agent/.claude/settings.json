{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "model": "Claude-Opus-4.5",
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); used=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); if [ -n \"$used\" ]; then printf \"%.1f%% used\" \"$used\"; fi"
  },
  "enabledPlugins": {
    "atlassian@claude-plugins-official": true,
    "analysis-tools@tilebuilder-marketplace": true,
    "calibre-drv-expert@tilebuilder-marketplace": true,
    "eco-timing-closure-flow@tilebuilder-marketplace": true,
    "fcfp-expert-skills@tilebuilder-marketplace": true,
    "fsdb-metrics@tilebuilder-marketplace": true,
    "gatecdc@tilebuilder-marketplace": true,
    "ml-cac@tilebuilder-marketplace": true,
    "pcfixeco-assistant@tilebuilder-marketplace": true,
    "rtl-fixme-advisor@tilebuilder-marketplace": true,
    "rtl-ppa-optimizer@tilebuilder-marketplace": true,
    "supra-doc@tilebuilder-marketplace": true,
    "tcm-lint@tilebuilder-marketplace": true,
    "tilebuilder-development@tilebuilder-marketplace": true,
    "tilebuilder-infra@tilebuilder-marketplace": true,
    "tilebuilder-supra-fe@tilebuilder-marketplace": true,
    "tilebuilder-supra-funceco@tilebuilder-marketplace": true,
    "tilebuilder-supra-pnr@tilebuilder-marketplace": true
  },
  "extraKnownMarketplaces": {
    "tilebuilder-marketplace": {
      "source": {
        "source": "directory",
        "path": "/tool/aticad/1.0/flow/TileBuilder/genie/marketplace"
      }
    }
  },
  "alwaysThinkingEnabled": true
}
